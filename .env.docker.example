# Copy to .env.docker and replace all placeholders before deployment.
# Then run: docker compose --env-file .env.docker up -d --build

POSTGRES_DB=auth_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

JWT_SECRET=replace-with-64-char-random-secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_DAYS=7
BCRYPT_SALT_ROUNDS=10

RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=30
AUTH_STRICT_RATE_LIMIT_MAX=10

SENDGRID_API_KEY=SG.replace-with-real-sendgrid-key
EMAIL_FROM=no-reply@yourdomain.com

FRONTEND_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com
ENFORCE_ORIGIN_CHECK=true
COOKIE_SAME_SITE=strict
COOKIE_SECURE=true

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

VERIFY_CODE_EXPIRES_MINUTES=10
RESET_TOKEN_EXPIRES_MINUTES=60

FRONTEND_PORT=80
